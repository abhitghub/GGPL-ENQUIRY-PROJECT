# Copy this file to .env and fill in real values before deploying.
# .env is gitignored — never commit real secrets. Put real values in .env, not here.

# Long random string used to sign login session cookies. REQUIRED for production.
# Generate one, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=change-me-to-a-long-random-string

# Postgres password for the bundled database (docker-compose.prod.yml).
POSTGRES_PASSWORD=change-me

# OpenAI key used for enquiry text extraction / smart parsing.
OPENAI_API_KEY=sk-...

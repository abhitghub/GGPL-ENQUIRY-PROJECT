{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "npm run dev",
        "type": "shell",
        "command": "cmd",
        "args": ["/c", "npm.cmd", "run", "dev"],
        "options": {
          "cwd": "${workspaceFolder}/apps/web"
        },
        "isBackground": true
      },
      {
        "label": "npm run build",
        "type": "shell",
        "command": "cmd",
        "args": ["/c", "npm.cmd", "run", "build"],
        "options": {
          "cwd": "${workspaceFolder}/apps/web"
        },
        "group": "build",
        "problemMatcher": []
      }
    ]
  }